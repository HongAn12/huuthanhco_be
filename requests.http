### ============================================================
### Huu Thanh Co API — VS Code REST Client test file
### Install extension: "REST Client" by Huachao Mao
### ============================================================

@base = http://localhost:4000/api

### Paste access token here after login:
@token = PASTE_ACCESS_TOKEN_HERE
@refreshToken = PASTE_REFRESH_TOKEN_HERE


# ─── AUTH ────────────────────────────────────────────────────

### Login
# @name login
POST {{base}}/auth/login
Content-Type: application/json

{
  "email": "admin@huuthanhco.com",
  "password": "Admin@2024!!"
}

###

### Refresh access token
POST {{base}}/auth/refresh
Content-Type: application/json

{
  "refreshToken": "{{refreshToken}}"
}

###

### Get current user info
GET {{base}}/auth/me
Authorization: Bearer {{token}}

###

### Logout
POST {{base}}/auth/logout
Content-Type: application/json

{
  "refreshToken": "{{refreshToken}}"
}

###

### List admin users (super_admin only)
GET {{base}}/auth/users
Authorization: Bearer {{token}}

###

### Create admin user (super_admin only)
POST {{base}}/auth/users
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "email": "editor2@huuthanhco.com",
  "password": "Editor@2024!!",
  "fullName": "Biên tập viên 2",
  "role": "editor"
}

###

### Update admin user
PUT {{base}}/auth/users/USER_ID_HERE
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "fullName": "Tên mới"
}

###

### Delete admin user
DELETE {{base}}/auth/users/USER_ID_HERE
Authorization: Bearer {{token}}


# ─── NEWS ────────────────────────────────────────────────────

### List all news (public)
GET {{base}}/news

###

### Get news by ID or slug (public)
GET {{base}}/news/tin-tuc-1

###

### Create news article
POST {{base}}/news
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "id": "00000000-0000-0000-0000-000000000001",
  "title": "Tin tức mới nhất",
  "titleEn": "Latest News",
  "slug": "tin-tuc-moi-nhat",
  "date": "2024-01-15",
  "category": "Công ty",
  "categoryEn": "Company",
  "thumbnail": "https://example.com/image.jpg",
  "excerpt": "Tóm tắt bài viết...",
  "excerptEn": "Article excerpt...",
  "content": "<p>Nội dung đầy đủ bài viết</p>",
  "contentEn": "<p>Full article content</p>"
}

###

### Update news article
PUT {{base}}/news/00000000-0000-0000-0000-000000000001
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "id": "00000000-0000-0000-0000-000000000001",
  "title": "Tin tức cập nhật",
  "titleEn": "Updated News",
  "slug": "tin-tuc-moi-nhat",
  "date": "2024-01-16",
  "category": "Công ty",
  "categoryEn": "Company",
  "thumbnail": "https://example.com/image.jpg",
  "excerpt": "Tóm tắt cập nhật",
  "excerptEn": "Updated excerpt",
  "content": "<p>Nội dung cập nhật</p>",
  "contentEn": "<p>Updated content</p>"
}

###

### Delete news article
DELETE {{base}}/news/00000000-0000-0000-0000-000000000001
Authorization: Bearer {{token}}


# ─── PROJECTS ────────────────────────────────────────────────

### List all projects (public)
GET {{base}}/projects

###

### Get project by ID or slug (public)
GET {{base}}/projects/du-an-1

###

### Create project
POST {{base}}/projects
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "id": "00000000-0000-0000-0000-000000000002",
  "name": "Dự án Hữu Thành Tower",
  "nameEn": "Huu Thanh Tower Project",
  "location": "TP. Hồ Chí Minh",
  "year": 2024,
  "category": "Nhà ở",
  "categoryEn": "Residential",
  "image": "https://example.com/project.jpg",
  "description": "Mô tả dự án...",
  "descriptionEn": "Project description..."
}

###

### Update project
PUT {{base}}/projects/00000000-0000-0000-0000-000000000002
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "id": "00000000-0000-0000-0000-000000000002",
  "name": "Dự án cập nhật",
  "nameEn": "Updated Project",
  "location": "Hà Nội",
  "year": 2024,
  "category": "Thương mại",
  "categoryEn": "Commercial",
  "image": "https://example.com/project2.jpg",
  "description": "Mô tả mới",
  "descriptionEn": "New description"
}

###

### Delete project
DELETE {{base}}/projects/00000000-0000-0000-0000-000000000002
Authorization: Bearer {{token}}

###

### List project images
GET {{base}}/projects/00000000-0000-0000-0000-000000000002/images
Authorization: Bearer {{token}}

###

### Add image to project
POST {{base}}/projects/00000000-0000-0000-0000-000000000002/images
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "url": "https://example.com/gallery1.jpg",
  "caption": "Mặt tiền tòa nhà",
  "captionEn": "Building facade",
  "sortOrder": 1
}

###

### Delete project image
DELETE {{base}}/projects/00000000-0000-0000-0000-000000000002/images/IMAGE_ID_HERE
Authorization: Bearer {{token}}

###

### Reorder project images
PATCH {{base}}/projects/00000000-0000-0000-0000-000000000002/images/reorder
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "ids": ["IMAGE_ID_1", "IMAGE_ID_2", "IMAGE_ID_3"]
}


# ─── JOBS ────────────────────────────────────────────────────

### List all jobs (public)
GET {{base}}/jobs

###

### Get job by ID or slug (public)
GET {{base}}/jobs/ke-toan-truong

###

### Create job posting
POST {{base}}/jobs
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "id": "00000000-0000-0000-0000-000000000003",
  "title": "Kế Toán Trưởng",
  "titleEn": "Chief Accountant",
  "location": "TP. Hồ Chí Minh",
  "type": "Toàn thời gian",
  "typeEn": "Full-time",
  "salary": "Thỏa thuận",
  "description": "Mô tả công việc...",
  "descriptionEn": "Job description...",
  "requirements": ["Tốt nghiệp đại học chuyên ngành Kế toán", "Kinh nghiệm 3 năm"],
  "requirementsEn": ["Bachelor in Accounting", "3 years experience"]
}

###

### Update job
PUT {{base}}/jobs/00000000-0000-0000-0000-000000000003
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "id": "00000000-0000-0000-0000-000000000003",
  "title": "Kế Toán Trưởng (Cập nhật)",
  "titleEn": "Chief Accountant (Updated)",
  "location": "Hà Nội",
  "type": "Toàn thời gian",
  "typeEn": "Full-time",
  "salary": "20-30 triệu",
  "description": "Mô tả cập nhật",
  "descriptionEn": "Updated description",
  "requirements": ["Yêu cầu mới"],
  "requirementsEn": ["New requirement"]
}

###

### Delete job
DELETE {{base}}/jobs/00000000-0000-0000-0000-000000000003
Authorization: Bearer {{token}}


# ─── JOB APPLICATIONS ────────────────────────────────────────

### Submit job application (public)
POST {{base}}/job-applications
Content-Type: application/json

{
  "jobId": "00000000-0000-0000-0000-000000000003",
  "fullName": "Nguyễn Văn A",
  "phone": "0901234567",
  "email": "nguyenvana@email.com",
  "positionApplied": "Kế Toán Trưởng",
  "cvFileUrl": "https://example.com/cv.pdf",
  "message": "Tôi muốn ứng tuyển vị trí này"
}

###

### Submit application without job ID
POST {{base}}/job-applications
Content-Type: application/json

{
  "fullName": "Trần Thị B",
  "phone": "0912345678",
  "email": "tranthib@email.com",
  "positionApplied": "Nhân viên kinh doanh",
  "message": "Tôi muốn ứng tuyển"
}

###

### List applications (admin)
GET {{base}}/job-applications
Authorization: Bearer {{token}}

###

### List with filters
GET {{base}}/job-applications?status=new&limit=10&offset=0
Authorization: Bearer {{token}}

###

### Get single application
GET {{base}}/job-applications/APPLICATION_ID_HERE
Authorization: Bearer {{token}}

###

### Update application status
PATCH {{base}}/job-applications/APPLICATION_ID_HERE
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "status": "reviewing"
}

###

### Delete application (super_admin)
DELETE {{base}}/job-applications/APPLICATION_ID_HERE
Authorization: Bearer {{token}}


# ─── CONSULTATIONS ───────────────────────────────────────────

### Submit consultation request (public)
POST {{base}}/consultations
Content-Type: application/json

{
  "name": "Nguyễn Văn C",
  "phone": "0923456789",
  "email": "nguyenvanc@email.com",
  "service": "Tư vấn thiết kế nội thất",
  "message": "Tôi muốn tư vấn về thiết kế phòng khách"
}

###

### List consultations (admin)
GET {{base}}/consultations
Authorization: Bearer {{token}}

###

### List with status filter
GET {{base}}/consultations?status=new
Authorization: Bearer {{token}}

###

### Update consultation status
PATCH {{base}}/consultations/CONSULTATION_ID_HERE
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "status": "read"
}

###

### Delete consultation (super_admin)
DELETE {{base}}/consultations/CONSULTATION_ID_HERE
Authorization: Bearer {{token}}


# ─── SETTINGS ────────────────────────────────────────────────

### Get all settings (public)
GET {{base}}/settings

###

### Get settings by prefix (e.g. company info)
GET {{base}}/settings?prefix=company

###

### Get settings as key-value map
GET {{base}}/settings?full=false

###

### Get single setting
GET {{base}}/settings/company.name

###

### Upsert single setting
PUT {{base}}/settings/company.name
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "value": "Công Ty TNHH Hữu Thành",
  "valueEn": "Huu Thanh Co., Ltd.",
  "type": "text"
}

###

### Bulk save settings (company info + SEO)
POST {{base}}/settings/bulk
Authorization: Bearer {{token}}
Content-Type: application/json

[
  { "key": "company.name", "value": "Công Ty TNHH Hữu Thành", "valueEn": "Huu Thanh Co., Ltd.", "type": "text" },
  { "key": "company.phone", "value": "0981806676", "type": "text" },
  { "key": "company.email", "value": "info@huuthanhco.com", "type": "text" },
  { "key": "company.address", "value": "123 Đường ABC, Quận 1, TP. HCM", "valueEn": "123 ABC Street, District 1, HCMC", "type": "text" },
  { "key": "company.taxCode", "value": "0123456789", "type": "text" },
  { "key": "seo.title", "value": "Hữu Thành - Đơn vị thi công uy tín", "valueEn": "Huu Thanh - Trusted Construction", "type": "text" },
  { "key": "seo.description", "value": "Chuyên thi công nội thất, xây dựng dân dụng chất lượng cao tại TP.HCM", "valueEn": "Specializing in high-quality interior and civil construction in HCMC", "type": "text" },
  { "key": "seo.keywords", "value": "thi công nội thất, xây dựng, hữu thành", "valueEn": "interior construction, building, huu thanh", "type": "text" }
]

###

### Delete a setting (super_admin)
DELETE {{base}}/settings/company.name
Authorization: Bearer {{token}}


# ─── MEDIA LIBRARY ───────────────────────────────────────────

### List media files (admin)
GET {{base}}/media
Authorization: Bearer {{token}}

###

### List by folder
GET {{base}}/media?folder=news
Authorization: Bearer {{token}}

###

### List by type
GET {{base}}/media?fileType=image
Authorization: Bearer {{token}}

###

### Get single media file
GET {{base}}/media/MEDIA_ID_HERE
Authorization: Bearer {{token}}

###

### Add media record (after uploading to cloud storage)
POST {{base}}/media
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "fileName": "banner-homepage.jpg",
  "fileUrl": "https://your-storage.com/media/banner-homepage.jpg",
  "fileType": "image/jpeg",
  "fileSize": 245678,
  "width": 1920,
  "height": 1080,
  "folder": "banners",
  "altText": "Banner trang chủ",
  "altTextEn": "Homepage banner"
}

###

### Update media metadata
PUT {{base}}/media/MEDIA_ID_HERE
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "altText": "Mô tả ảnh mới",
  "altTextEn": "New image description",
  "folder": "news"
}

###

### Delete media record
DELETE {{base}}/media/MEDIA_ID_HERE
Authorization: Bearer {{token}}


# ─── CMS BULK SYNC ───────────────────────────────────────────

### Get all CMS content
GET {{base}}/cms

###

### Replace all CMS content at once (admin)
POST {{base}}/cms
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "news": [
    {
      "id": "00000000-0000-0000-0000-000000000001",
      "title": "Tin tức mới nhất",
      "titleEn": "Latest News",
      "slug": "tin-tuc-moi-nhat",
      "date": "2024-01-15",
      "category": "Công ty",
      "categoryEn": "Company",
      "thumbnail": "https://example.com/thumb.jpg",
      "excerpt": "Tóm tắt",
      "excerptEn": "Excerpt",
      "content": "<p>Nội dung</p>",
      "contentEn": "<p>Content</p>"
    }
  ],
  "projects": [],
  "jobs": []
}


# ─── HEALTH CHECK ────────────────────────────────────────────

### Health check
GET http://localhost:4000/api/health
