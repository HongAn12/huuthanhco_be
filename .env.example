# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Database (Neon hoac local Docker)
DATABASE_URL=postgres://postgres:secret@127.0.0.1:5432/huuthanh_cms

# JWT -- bat buoc doi trong production (dung: openssl rand -hex 32)
JWT_SECRET=change-me-must-be-at-least-32-chars-long!!
JWT_REFRESH_SECRET=change-me-refresh-different-from-above!!

# Tao admin dau tien (dung voi: npm run create-admin)
ADMIN_EMAIL=admin@huuthanh.vn
ADMIN_PASSWORD=Admin@123456
ADMIN_NAME=Super Admin

# Cloudflare R2
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_ENDPOINT=https://124830de785ccd3117effa8673736cac.r2.cloudflarestorage.com
R2_BUCKET=huuthanhco
R2_PUBLIC_URL=https://your-r2-public-domain.com
